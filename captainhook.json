{
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "vendor/bin/php-cs-fixer fix --dry-run --diff"
            },
            {
                "action": "vendor/bin/phpstan analyse --memory-limit=1G --no-progress"
            },
            {
                "action": "vendor/bin/phpunit --testsuite=Unit"
            }
        ]
    },
    "commit-msg": {
        "enabled": false,
        "actions": []
    },
    "pre-push": {
        "enabled": false,
        "actions": []
    }
}
